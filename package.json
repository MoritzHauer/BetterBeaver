{
  "name": "betterbeaver",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "corepack pnpm run format:check && corepack pnpm run lint && corepack pnpm run typecheck && corepack pnpm run test",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "corepack pnpm -r run typecheck",
    "test": "vitest run",
    "dev": "corepack pnpm --filter @betterbeaver/web dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
